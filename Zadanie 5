DROP DATABASE IF EXISTS Moje_zainteresowania;
CREATE DATABASE Moje_zainteresowania;

USE Moje_zainteresowania;

SET autocommit=1; 

CREATE TABLE Zainteresowania (
ID INTEGER PRIMARY KEY AUTO_INCREMENT,
NAZWA TEXT NOT NULL,
OPIS TEXT NOT NULL,
DATA_REALIZACJI DATE);

