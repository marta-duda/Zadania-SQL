SELECT Produkty.* FROM Produkty
JOIN Producenci ON Produkty.id_producenta=Producenci.id_producenta
WHERE Producenci.id_producenta=1
ORDER BY nazwa_produktu;

SELECT AVG(cena_brutto_zakupu) FROM Produkty
WHERE id_producenta=1;

SELECT id_produktu,cena_brutto_zakupu,
CASE
WHEN cena_brutto_zakupu<35 THEN 'TANIE'
WHEN cena_brutto_zakupu>35 THEN 'DROGIE'
END AS 'TANIE/DROGIE'
FROM Produkty;

SELECT nazwa_produktu FROM Produkty
JOIN Zamowienia ON Produkty.id_produktu=Zamowienia.id_produktu;

SELECT nazwa_produktu FROM Produkty
JOIN Zamowienia ON Produkty.id_produktu=Zamowienia.id_produktu;
LIMIT 5;

SELECT SUM(cena_brutto_sprzedazy) FROM Produkty
JOIN Zamowienia ON Produkty.id_produktu=Zamowienia.id_produktu;

SELECT id_zamowienia,nazwa_produktu,data_zamowienia FROM Zamowienia
JOIN Produkty ON Zamowienia.id_produktu=Produkty.id_produktu
ORDER BY data_zamowienia;

SELECT * FROM Produkty
WHERE
id_produktu IS NULL OR
id_producenta IS NULL OR
nazwa_produktu IS NULL OR
opis_produktu IS NULL OR
cena_netto_zakupu IS NULL OR
cena_brutto_zakupu IS NULL OR
cena_netto_sprzedazy IS NULL OR
cena_brutto_sprzedazy IS NULL OR
procent_VAT  IS NULL;

SELECT Zamowienia.id_zamowienia, Produkty.nazwa_produktu, Produkty.cena_brutto_sprzedazy FROM Produkty
JOIN Zamowienia ON Produkty.id_produktu=Zamowienia.id_produktu
LIMIT 1;

SELECT data_zamowienia, COUNT(*) AS liczba_zamowien
FROM Zamowienia
GROUP BY data_zamowienia
ORDER BY liczba_zamowien DESC
LIMIT 1;
