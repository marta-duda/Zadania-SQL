CREATE DATABASE Sklep_odziezowy;

USE Sklep_odziezowy;

CREATE TABLE Producenci(
id_producenta INTEGER AUTO_INCREMENT PRIMARY KEY,
nazwa_producenta VARCHAR(50) NOT NULL,
adres_producenta VARCHAR(50) NOT NULL,
nip_producenta VARCHAR(10) UNIQUE,
data_podpisania_umowy DATE NOT NULL
);

CREATE TABLE Produkty(
id_produktu INTEGER AUTO_INCREMENT PRIMARY KEY,
id_producenta INTEGER NOT NULL,
nazwa_produktu VARCHAR(50) NOT NULL,
opis_produktu VARCHAR(150) NOT NULL,
cena_netto_zakupu DECIMAL(10,2) NOT NULL,
cena_brutto_zakupu DECIMAL(10,2) NOT NULL,
cena_netto_sprzedazy DECIMAL(10,2) NOT NULL,
cena_brutto_sprzedazy DECIMAL(10,2) NOT NULL,
procent_VAT INTEGER NOT NULL,
FOREIGN KEY (id_producenta) REFERENCES Producenci(id_producenta)
);

CREATE TABLE Klienci(
id_klienta INTEGER auto_increment PRIMARY KEY,
imie VARCHAR(50) NOT NULL,
nazwisko VARCHAR(50) NOT NULL,
adres VARCHAR(150) NOT NULL
);

CREATE TABLE Zamowienia(
id_zamowienia INTEGER AUTO_INCREMENT PRIMARY KEY,
id_klienta INTEGER NOT NULL,
id_produktu INTEGER NOT NULL,
data_zamowienia DATE NOT NULL,
FOREIGN KEY (id_produktu) REFERENCES Produkty(id_produktu),
FOREIGN KEY (id_klienta) REFERENCES Klienci(id_klienta)
);

